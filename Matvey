<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>2026</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        
        body {
            background-color: #f8f9fa;
            color: #333;
            line-height: 1.6;
            padding: 20px;
        }
        
        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 20px;
        }
        
        header {
            text-align: center;
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 2px solid #4a6fa5;
        }
        
        h1 {
            color: #2c3e50;
            font-size: 2.2rem;
            margin-bottom: 10px;
        }
        
        .year-label {
            font-size: 1.3rem;
            color: #4a6fa5;
            font-weight: 600;
            letter-spacing: 2px;
        }
        
        .calendar-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 25px;
            margin-bottom: 30px;
        }
        
        .month-container {
            background-color: white;
            border-radius: 12px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.08);
            overflow: hidden;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        
        .month-container:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.12);
        }
        
        .month-header {
            background-color: #4a6fa5;
            color: white;
            padding: 15px;
            text-align: center;
            font-size: 1.4rem;
            font-weight: 600;
        }
        
        .calendar {
            width: 100%;
            padding: 15px;
            border-collapse: collapse;
        }
        
        .calendar th {
            color: #4a6fa5;
            font-weight: 600;
            padding: 10px 5px;
            font-size: 0.9rem;
            text-align: center;
            border-bottom: 1px solid #eee;
        }
        
        .calendar td {
            text-align: center;
            padding: 10px 5px;
            font-size: 0.95rem;
            border-radius: 6px;
            transition: background-color 0.2s;
            position: relative;
            width: 40px;
            height: 40px;
        }
        
        .calendar td:hover {
            background-color: #f0f4ff;
        }
        
        .calendar td.weekend {
            color: #e74c3c;
            font-weight: 600;
            background-color: #FFF9F0;
        }
        
        .calendar td.package-20day {
            background-color: rgba(144, 238, 144, 0.4);
            font-weight: 600;
            color: #2c3e50;
        }
        
        .calendar td.package-matvey {
            font-weight: 700;
            color: #2c3e50;
            border: 2px solid #1e6bb8;
            background-color: white;
        }
        
        .calendar td.both-packages {
            background-color: rgba(144, 238, 144, 0.4);
            font-weight: 700;
            color: #2c3e50;
            border: 2px solid #1e6bb8;
        }
        
        .calendar td.other-month {
            color: #ccc;
        }
        
        .legend {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 20px;
            margin-top: 30px;
            padding: 20px;
            background-color: white;
            border-radius: 10px;
            box-shadow: 0 3px 10px rgba(0, 0, 0, 0.08);
            max-width: 1000px;
            margin-left: auto;
            margin-right: auto;
        }
        
        .legend-item {
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .legend-color {
            width: 20px;
            height: 20px;
            border-radius: 4px;
        }
        
        .legend-border {
            width: 20px;
            height: 20px;
            border-radius: 4px;
            border: 2px solid;
        }
        
        .weekend-color {
            background-color: #FFF9F0;
            border: 1px solid #e74c3c;
        }
        
        .package-20day-color {
            background-color: rgba(144, 238, 144, 0.4);
            border: 1px solid #90EE90;
        }
        
        .package-matvey-color {
            background-color: white;
            border: 2px solid #1e6bb8;
        }
        
        .both-packages-color {
            background-color: rgba(144, 238, 144, 0.4);
            border: 2px solid #1e6bb8;
        }
        
        footer {
            text-align: center;
            margin-top: 40px;
            padding-top: 20px;
            border-top: 1px solid #ddd;
            color: #777;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>2026</h1>
            <div class="year-label">Matvey's Calendar</div>
        </header>
        
        <main>
            <div class="calendar-grid" id="calendar-container"></div>
            
            <div class="legend">
                <div class="legend-item"><div class="legend-color weekend-color"></div><span>Выходные дни</span></div>
                <div class="legend-item"><div class="legend-color package-20day-color"></div><span>Пакет 20 дней (февраль-март)</span></div>
                <div class="legend-item"><div class="legend-border package-matvey-color"></div><span>Занятие Матвея</span></div>
                <div class="legend-item"><div class="legend-border both-packages-color"></div><span>Оба события (пакет + Матвей)</span></div>
            </div>
        </main>
        
        <footer>
            <p>Календарь создан с использованием HTML, CSS и JavaScript</p>
            <p>© 2026 Календарь с выделенными пакетами дней</p>
        </footer>
    </div>

    <script>
        const monthNames = ["Январь", "Февраль", "Март", "Апрель", "Май", "Июнь", "Июль", "Август", "Сентябрь", "Октябрь", "Ноябрь", "Декабрь"];
        const dayNames = ["Пн", "Вт", "Ср", "Чт", "Пт", "Сб", "Вс"];
        const year = 2026;
        
        const package20Days = [
            "2026-02-04", "2026-02-05", "2026-02-06",
            "2026-02-09", "2026-02-10", "2026-02-11", "2026-02-12", "2026-02-13",
            "2026-02-16", "2026-02-17", "2026-02-18", "2026-02-19", "2026-02-20",
            "2026-02-23", "2026-02-24", "2026-02-25", "2026-02-26", "2026-02-27",
            "2026-03-02", "2026-03-03"
        ];
        
        const packageMatvey = [
            "2026-02-04", "2026-02-09", "2026-02-11", "2026-02-16",
            "2026-02-18", "2026-02-23", "2026-02-25", "2026-03-02"
        ];
        
        function getDaysInMonth(year, month) {
            return new Date(year, month + 1, 0).getDate();
        }
        
        function getFirstDayOfMonth(year, month) {
            const firstDay = new Date(year, month, 1).getDay();
            return firstDay === 0 ? 6 : firstDay - 1;
        }
        
        function formatDate(year, month, day) {
            return `${year}-${String(month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
        }
        
        function isInPackage20Days(year, month, day) {
            return package20Days.includes(formatDate(year, month, day));
        }
        
        function isInPackageMatvey(year, month, day) {
            return packageMatvey.includes(formatDate(year, month, day));
        }
        
        function createMonthCalendar(year, month) {
            const daysInMonth = getDaysInMonth(year, month);
            const firstDayIndex = getFirstDayOfMonth(year, month);
            
            let html = `<div class="month-container"><div class="month-header">${monthNames[month]} ${year}</div><table class="calendar"><thead> <tr>`;
            
            for (let day of dayNames) {
                const isWeekend = day === "Сб" || day === "Вс";
                html += `<th${isWeekend ? ' style="color:#e74c3c;"' : ''}>${day}</th>`;
            }
            
            html += `</tr></thead><tbody>`;
            
            let dayCounter = 1;
            
            for (let week = 0; week < 6; week++) {
                html += "<tr>";
                
                for (let dayOfWeek = 0; dayOfWeek < 7; dayOfWeek++) {
                    if (week === 0 && dayOfWeek < firstDayIndex) {
                        const prevMonthDays = getDaysInMonth(year, month - 1);
                        const prevMonthDay = prevMonthDays - (firstDayIndex - dayOfWeek - 1);
                        html += `<td class="other-month">${prevMonthDay}</td>`;
                    } else if (dayCounter > daysInMonth) {
                        const nextMonthDay = dayCounter - daysInMonth;
                        html += `<td class="other-month">${nextMonthDay}</td>`;
                        dayCounter++;
                    } else {
                        const isWeekend = dayOfWeek === 5 || dayOfWeek === 6;
                        const inPackage = isInPackage20Days(year, month, dayCounter);
                        const inMatvey = isInPackageMatvey(year, month, dayCounter);
                        
                        let dayClass = isWeekend ? " weekend" : "";
                        
                        if (inPackage && inMatvey) {
                            dayClass += " both-packages";
                        } else if (inPackage) {
                            dayClass += " package-20day";
                        } else if (inMatvey) {
                            dayClass += " package-matvey";
                        }
                        
                        html += `<td class="${dayClass}">${dayCounter}</td>`;
                        dayCounter++;
                    }
                }
                
                html += "</tr>";
                if (dayCounter > daysInMonth) break;
            }
            
            html += `</tbody></table></div>`;
            return html;
        }
        
        function createYearCalendar() {
            const container = document.getElementById("calendar-container");
            for (let month = 0; month < 12; month++) {
                container.innerHTML += createMonthCalendar(year, month);
            }
        }
        
        document.addEventListener("DOMContentLoaded", createYearCalendar);
    </script>
</body>
</html>
